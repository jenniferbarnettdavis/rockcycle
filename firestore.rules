rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for User entity
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'lastSeen']) 
        && data.keys().size() == 2
        && data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50
        && data.lastSeen == request.time;
    }

    // Validation for Completion entity
    function isValidCompletion(data) {
      return data.keys().hasAll(['userId', 'displayName', 'completedAt', 'score'])
        && data.keys().size() == 4
        && data.userId == request.auth.uid
        && data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50
        && data.completedAt == request.time
        && data.score is number;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.displayName != null; // basic safe list
      allow create, update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
    }

    match /completions/{completionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidCompletion(incoming());
      allow update, delete: if false; // Completions are immutable
    }
  }
}
